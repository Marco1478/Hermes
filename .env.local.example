# Copy this file to .env.local (already git-ignored) and fill in the
# real value. It's the same API_SERVER_KEY you generated with
# `openssl rand -hex 24` and set on the Hermes gateway.
VITE_GATEWAY_API_KEY=

# Hermes WebUI dashboard (separate service from the gateway above, e.g.
# http://192.168.2.11:9119) — the only place that can actually change
# Hermes's live model (POST /api/default-model, hot-reload, no restart).
# Login is username + password + session cookie (POST /auth/password-login,
# confirmed live), not a bearer key. These are deliberately NOT
# VITE_-prefixed so Vite never bundles them into browser code — only the
# dev server (vite-plugins/hermesDashboard.js) reads them, and only
# same-origin /local/dashboard/* is exposed to the browser. Changing the
# model here is GLOBAL: it affects Telegram, Discord, every platform
# Hermes serves, not just this chat.
#
# IMPORTANT: password_hash (if you found one in the box's own storage) is
# USELESS here — it's a one-way PBKDF2 hash, this needs the PLAINTEXT
# password. If you don't have the plaintext, log into the dashboard in
# your own browser (you likely already have a saved session) and set a
# fresh password from Settings > Security — that plaintext is what goes
# below.
HERMES_DASHBOARD_BASE_URL=http://192.168.2.11:9119
HERMES_DASHBOARD_USERNAME=
HERMES_DASHBOARD_PASSWORD=
