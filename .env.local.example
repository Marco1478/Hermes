# Copy this file to .env.local (already git-ignored) and fill in the
# real value. It's the same API_SERVER_KEY you generated with
# `openssl rand -hex 24` and set on the Hermes gateway.
VITE_GATEWAY_API_KEY=

# Hermes Dashboard (separate service from the gateway above, e.g.
# http://192.168.2.11:9119, the SAME nousresearch/hermes-agent image just
# started with `hermes dashboard` instead of `hermes gateway run`) — the
# only place that can actually change Hermes's live model
# (POST /api/model/set — NOT /api/default-model, which 404s on this
# build despite being the first guess). Login is username + password +
# session cookie (POST /auth/password-login), not a bearer key. These are
# deliberately NOT VITE_-prefixed so Vite never bundles them into browser
# code — only the dev server (vite-plugins/hermesBridge.js) reads them,
# and only same-origin /local/hermes/* is exposed to the browser.
# Changing the model here is GLOBAL: it affects Telegram, Discord, every
# platform Hermes serves, not just this chat.
#
# To set/reset this password on the box itself (found the hard way — see
# session history): the real config key is dashboard.basic_auth.password
# (plaintext) or .password_hash (scrypt, via
# plugins.dashboard_auth.basic.hash_password) in config.yaml, or the env
# var HERMES_DASHBOARD_BASIC_AUTH_PASSWORD on the container — NOT
# HERMES_WEBUI_PASSWORD, which belongs to an unrelated third-party
# project and does nothing here. A stale password_hash always wins over a
# newly-set plaintext password, so `hermes config unset
# dashboard.basic_auth.password_hash` after setting a new plaintext one.
# The dashboard process reads config ONCE at startup — after any change,
# `docker exec <container> hermes dashboard --stop` then
# `docker exec -d <container> hermes dashboard --host 0.0.0.0` (keep the
# --host flag or it rebinds to loopback-only and becomes unreachable).
HERMES_DASHBOARD_BASE_URL=http://192.168.2.11:9119
HERMES_DASHBOARD_USERNAME=
HERMES_DASHBOARD_PASSWORD=

# Kanban has no HTTP endpoint on this build (verified: no "kanban" route in
# web_server.py) — the bridge SSHes into the box and runs the real
# `hermes kanban ...` CLI inside the container instead. Same bridge as
# CLAUDE.md's "Accesso SSH al box" section. Key file itself is never
# committed; only its path goes here.
HERMES_SSH_HOST=root@192.168.2.11
HERMES_SSH_KEY_PATH=
